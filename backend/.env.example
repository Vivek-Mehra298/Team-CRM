# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas)
# Get this from: https://cloud.mongodb.com -> Your Cluster -> Connect -> Connection String
# Replace <password> with your actual MongoDB user password
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?appName=Cluster0

# JWT Secret for authentication (use a strong random string in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Redis Configuration (optional - app uses in-memory fallback if not set)
REDIS_URL=
