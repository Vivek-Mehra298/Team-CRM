# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB Atlas)
# Get this from: https://cloud.mongodb.com -> Your Cluster -> Connect -> Connection String
# Replace <password> with your actual MongoDB user password
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?appName=Cluster0

# JWT Secret for authentication (use a strong random string in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Frontend URL (for CORS) - Update with your Vercel frontend URL in production
CLIENT_URL=https://team-crm-nine.vercel.app
CORS_ORIGIN=https://team-crm-nine.vercel.app

# Redis Configuration (optional - app uses in-memory fallback if not set)
REDIS_URL=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="TeamCRM <your-email@gmail.com>"

